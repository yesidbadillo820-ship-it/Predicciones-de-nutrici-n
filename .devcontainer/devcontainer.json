{
  "name": "NutriPredict Escolar",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "forwardPorts": [8090, 8080],
  "portsAttributes": {
    "8090": { "label": "NutriPredict (microservicios)", "onAutoForward": "openBrowser" },
    "8080": { "label": "NutriPredict (monolito)", "onAutoForward": "silent" }
  },
  "postCreateCommand": "cd microservices && docker compose up -d --build",
  "postAttachCommand": "bash .devcontainer/welcome.sh",
  "customizations": {
    "vscode": {
      "extensions": ["bmewburn.vscode-intelephense-client"]
    }
  }
}
