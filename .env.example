# =============================================================
# NutriPredict Escolar — Variables de entorno (ejemplo)
# Copia este archivo a `.env` y completa los valores reales.
# El archivo `.env` NO debe subirse al repositorio.
# =============================================================

# Entorno: production | development
APP_ENV=production
APP_DEBUG=false

# ── Base de datos ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nutripredict_db
DB_USER=nutripredict
DB_PASS=cambia_esta_clave

# ── NutriBot (Claude AI) ──
# Sin esta clave, NutriBot responde con mensajes de respaldo basados en datos reales.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
